---
import BaseLayout from '../layouts/BaseLayout.astro';
import questionData from '../../content/questions.json';

const base = import.meta.env.BASE_URL;
const totalQuestions = questionData.categories.reduce(
  (sum, category) => sum + category.questions.length,
  0
);
---
<BaseLayout
  title="CAD利用技術者試験 2次元2級 無料Web演習 | 過去問道場"
  description={`CAD利用技術者試験 2次元2級の無料Web演習サイト。スマホ・PC対応、出題範囲を${questionData.categories.length}分野・全${totalQuestions}問の一問一答で対策。線種・投影法・断面など図付き問題も収録。やさしい解説つきで、間違えた問題だけをまとめて復習できます。登録不要ですぐに始められます。`}
>
  <section class="card">
    <h1>CAD利用技術者試験 2次元2級の無料Web演習</h1>
    <p class="lead">スマホでもPCでも、すきま時間にサクッと問題演習。CAD試験の出題範囲を分野ごとに、選択するだけのかんたん操作で対策できます。</p>
    <ul>
      <li><strong>{questionData.categories.length}分野・全{totalQuestions}問</strong>を一問一答で解ける</li>
      <li>答えるとすぐに正解・不正解と<strong>やさしい解説</strong>が読める</li>
      <li>間違えた問題は<strong>自動でリスト化</strong>、あとからまとめて復習できる</li>
      <li>会員登録もアプリのインストールも不要。<strong>このまますぐ始められる</strong></li>
    </ul>
    <div class="grid" style="margin-top: 1rem;">
      <a class="button primary" href={`${base}quiz/${questionData.categories[0].id}/`}>今すぐ演習を始める</a>
      <a class="button" href={`${base}review/`}>間違えた問題を復習する</a>
    </div>
  </section>

  <section class="card">
    <h2>分野別演習</h2>
    <p>気になる分野を選んで、一問一答で取り組めます。解いた内容は自動で記録され、苦手のチェックに役立ちます。</p>
    <div class="grid">
      {questionData.categories.map((category) => (
        <a class="button" href={`${base}quiz/${category.id}/`}>{category.name}（{category.questions.length}問）</a>
      ))}
    </div>
  </section>

  <section class="card">
    <h2>このサイトでできること</h2>
    <div class="grid">
      <a class="button" href={`${base}review/`}>間違えた問題だけを復習する</a>
      <a class="button" href={`${base}stats/`}>分野ごとの正答率を確認する</a>
    </div>
  </section>

  <section class="card">
    <h2>使い方はかんたん3ステップ</h2>
    <ol>
      <li>気になる分野を選んで、問題を解く</li>
      <li>その場で正解とやさしい解説をチェック</li>
      <li>間違えた問題を「復習」でおさらいする</li>
    </ol>
    <p class="note">※ 学習の記録はお使いのブラウザに保存されます。ブラウザのデータ（履歴・サイトデータ）を消去したり、別の端末・ブラウザに変えると記録は引き継がれません。</p>
  </section>
</BaseLayout>
