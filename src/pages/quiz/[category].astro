---
import BaseLayout from '../../layouts/BaseLayout.astro';
import questionData from '../../../content/questions.json';

const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  return questionData.categories.map((category) => ({
    params: { category: category.id },
    props: { category }
  }));
}

const { category } = Astro.props;
const payload = JSON.stringify({
  mode: 'category',
  categoryId: category.id,
  categoryName: category.name,
  categories: questionData.categories
});
---
<BaseLayout title={`${category.name} | 分野別演習`} description={`${category.name}の一問一答演習`}>
  <section class="card">
    <h2>{category.name} 演習</h2>
    <p>4択の一問一答です。回答直後に正誤と解説を表示します。</p>
    <div id="quiz-root"></div>
  </section>
  <script id="cad-app-data" type="application/json" set:html={payload}></script>
  <script type="module" src={`${base}scripts/quiz.js`}></script>
</BaseLayout>
