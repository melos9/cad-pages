---
import AdSlot from '../components/AdSlot.astro';

const {
  title,
  description = 'CAD利用技術者試験 2次元2級の無料Web演習。スマホ・PC対応、分野別の一問一答、誤答だけを復習できるモード、学習状況ダッシュボードを搭載。',
  pageType = 'website',
  noindex = false
} = Astro.props;

const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL('https://melos9.github.io');
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL(`${base}og-image.svg`, site).toString();
const siteName = 'CAD利用技術者試験 2次元2級 道場';
const fullTitle = title;

const baseTrim = base.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(/\/$/, '');
const navItems = [
  { href: base, label: 'トップ', match: baseTrim, exact: true },
  { href: `${base}quiz/cad-system/`, label: '分野別演習', match: `${baseTrim}/quiz` },
  { href: `${base}review/`, label: '復習', match: `${baseTrim}/review` },
  { href: `${base}stats/`, label: '学習状況', match: `${baseTrim}/stats` }
];

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? '';

const shareText = title;
const shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(canonical)}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: `${site.toString().replace(/\/$/, '')}${base}`,
  description,
  inLanguage: 'ja'
};
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1b4d91" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e2a55" media="(prefers-color-scheme: dark)" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="color-scheme" content="light dark" />
    {noindex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow,max-image-preview:large" />}
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="alternate" hreflang="ja" href={canonical} />

    <meta property="og:type" content={pageType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {adsenseClient && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
      />
    )}

    <style is:global>
      :root {
        --c-bg: #f4f6fb;
        --c-surface: #ffffff;
        --c-text: #1a1f36;
        --c-muted: #5c6b8a;
        --c-primary: #1b4d91;
        --c-primary-strong: #0e2a55;
        --c-accent: #ff8a3d;
        --c-border: #d6def0;
        --c-correct: #1b5e20;
        --c-correct-bg: #e7f5e8;
        --c-incorrect: #b71c1c;
        --c-incorrect-bg: #fdecea;
        --radius-lg: 14px;
        --radius-md: 10px;
        --shadow-sm: 0 1px 3px rgba(15, 30, 60, 0.06);
        --shadow-md: 0 4px 16px rgba(15, 30, 60, 0.08);
        --container: 980px;
        color-scheme: light;
        font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Yu Gothic UI', 'Segoe UI', 'Noto Sans JP', sans-serif;
        line-height: 1.7;
        -webkit-text-size-adjust: 100%;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--c-bg);
        color: var(--c-text);
        font-size: 16px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      a { color: var(--c-primary); }
      :focus-visible {
        outline: 3px solid #ffb648;
        outline-offset: 2px;
        border-radius: 6px;
      }
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
      }
      .skip-link:focus {
        left: 1rem;
        top: 1rem;
        background: #fff;
        padding: 0.6rem 1rem;
        border-radius: 8px;
        z-index: 1000;
        box-shadow: var(--shadow-md);
      }
      .container {
        width: 100%;
        max-width: var(--container);
        margin: 0 auto;
        padding: 0 1rem 2rem;
        flex: 1 0 auto;
      }
      .site-header {
        background: linear-gradient(135deg, var(--c-primary), var(--c-primary-strong));
        color: #fff;
        padding: 0.9rem 1rem 1rem;
        border-radius: 0 0 18px 18px;
        box-shadow: var(--shadow-md);
      }
      .site-header-inner {
        max-width: var(--container);
        margin: 0 auto;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.05rem;
        line-height: 1.3;
      }
      .brand-mark {
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
        padding: 0.18rem 0.55rem;
        border-radius: 6px;
        font-size: 0.78rem;
        letter-spacing: 0.04em;
      }
      .site-nav {
        margin-top: 0.75rem;
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
      }
      .site-nav a {
        color: #fff;
        text-decoration: none;
        background: rgba(255, 255, 255, 0.14);
        padding: 0.5rem 0.9rem;
        border-radius: 999px;
        font-size: 0.92rem;
        font-weight: 500;
        transition: background-color 0.15s;
        min-height: 40px;
        display: inline-flex;
        align-items: center;
      }
      .site-nav a:hover,
      .site-nav a:focus-visible {
        background: rgba(255, 255, 255, 0.28);
      }
      .site-nav a[aria-current='page'] {
        background: #fff;
        color: var(--c-primary-strong);
        font-weight: 700;
      }
      main { margin-top: 1.25rem; }
      h1, h2, h3 {
        line-height: 1.4;
        color: var(--c-primary-strong);
      }
      h1 { font-size: 1.45rem; margin: 0 0 0.6rem; }
      h2 { font-size: 1.2rem; margin: 0 0 0.6rem; }
      h3 { font-size: 1.05rem; margin: 1.1rem 0 0.4rem; }
      p { margin: 0.5rem 0; }
      ul, ol { padding-left: 1.4rem; }
      li { margin: 0.25rem 0; }
      .lead {
        color: var(--c-muted);
        font-size: 1rem;
      }
      .card {
        background: var(--c-surface);
        border-radius: var(--radius-lg);
        padding: 1.1rem 1.1rem 1.2rem;
        box-shadow: var(--shadow-sm);
        margin-top: 1rem;
      }
      .card:first-of-type { margin-top: 0; }
      .ad-slot {
        background: #eef2f9;
        border: 1px dashed #8ba0c7;
        border-radius: var(--radius-md);
        min-height: 88px;
        display: grid;
        place-items: center;
        color: var(--c-muted);
        margin: 1rem 0;
        font-size: 0.85rem;
      }
      .ad-slot::before { content: 'AdSense Placeholder'; }
      .button,
      button,
      .choice-btn {
        min-height: 48px;
        border-radius: var(--radius-md);
        border: 1px solid var(--c-border);
        background: #fff;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        font-family: inherit;
        color: var(--c-text);
        cursor: pointer;
        transition: transform 0.05s, border-color 0.15s, background-color 0.15s;
      }
      button:hover,
      .choice-btn:hover,
      .button:hover { border-color: var(--c-primary); }
      button:active,
      .choice-btn:active,
      .button:active { transform: translateY(1px); }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        text-decoration: none;
        color: var(--c-primary-strong);
        font-weight: 600;
        background: #fff;
      }
      .button::after {
        content: '›';
        color: var(--c-primary);
        font-size: 1.25rem;
        line-height: 1;
      }
      .button.primary {
        background: var(--c-primary);
        color: #fff;
        border-color: var(--c-primary);
      }
      .button.primary::after { color: #fff; }
      .choice-btn {
        text-align: left;
        width: 100%;
      }
      .choice-btn.correct {
        border-color: var(--c-correct);
        background: var(--c-correct-bg);
        color: var(--c-correct);
        font-weight: 600;
      }
      .choice-btn.incorrect {
        border-color: var(--c-incorrect);
        background: var(--c-incorrect-bg);
        color: var(--c-incorrect);
        font-weight: 600;
      }
      .grid { display: grid; gap: 0.7rem; }

      /* --- Quiz UI --- */
      .quiz {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--radius-lg);
        padding: 1.1rem;
        margin-top: 0.5rem;
      }
      .quiz-progress { margin-bottom: 1rem; }
      .quiz-progress-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: var(--c-muted);
        margin-bottom: 0.4rem;
      }
      .quiz-count { font-weight: 700; color: var(--c-text); }
      .quiz-cat {
        background: var(--c-bg);
        border: 1px solid var(--c-border);
        border-radius: 999px;
        padding: 0.15rem 0.7rem;
        font-size: 0.78rem;
      }
      .quiz-bar {
        height: 8px;
        background: var(--c-border);
        border-radius: 999px;
        overflow: hidden;
      }
      .quiz-bar-fill {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, var(--c-primary), var(--c-accent));
        border-radius: 999px;
        transition: width 0.3s ease;
      }
      .quiz-question {
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1.6;
        margin: 0 0 1rem;
        color: var(--c-text);
      }
      .quiz-figure {
        margin: 0 0 1rem;
        padding: 1rem;
        background: var(--c-bg);
        border: 1px solid var(--c-border);
        border-radius: var(--radius-md);
        display: flex;
        justify-content: center;
      }
      .quiz-figure svg {
        width: 100%;
        max-width: 320px;
        height: auto;
        color: var(--c-text);
      }
      .quiz-choices {
        display: grid;
        gap: 0.6rem;
      }
      .quiz-choices .choice-btn {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-height: 56px;
        padding: 0.7rem 0.9rem;
      }
      .choice-key {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--c-bg);
        border: 1px solid var(--c-border);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--c-primary);
      }
      .choice-text { flex: 1; line-height: 1.5; }
      .choice-btn.correct .choice-key {
        background: var(--c-correct);
        border-color: var(--c-correct);
        color: #fff;
      }
      .choice-btn.incorrect .choice-key {
        background: var(--c-incorrect);
        border-color: var(--c-incorrect);
        color: #fff;
      }
      .choice-btn.dimmed { opacity: 0.55; }
      .choice-btn:disabled { cursor: default; }
      .quiz-result { margin-top: 1rem; }
      .quiz-result .button { margin-top: 0.9rem; width: 100%; justify-content: center; }
      .quiz-result .button::after { content: none; }
      .result-box {
        border-radius: var(--radius-md);
        padding: 0.9rem 1rem;
        border: 1px solid var(--c-border);
      }
      .result-box.is-correct {
        background: var(--c-correct-bg);
        border-color: var(--c-correct);
      }
      .result-box.is-incorrect {
        background: var(--c-incorrect-bg);
        border-color: var(--c-incorrect);
      }
      .result-status {
        margin: 0 0 0.4rem;
        font-weight: 700;
        font-size: 1.05rem;
      }
      .is-correct .result-status { color: var(--c-correct); }
      .is-incorrect .result-status { color: var(--c-incorrect); }
      .result-explain { margin: 0; line-height: 1.7; }
      .quiz-summary { text-align: center; padding: 1.6rem 1.1rem; }
      .summary-title { font-size: 1.15rem; font-weight: 700; margin: 0 0 0.5rem; }
      .summary-score { font-size: 1.05rem; margin: 0 0 0.8rem; }
      .summary-score strong { font-size: 1.6rem; color: var(--c-primary); }
      .quiz-summary .quiz-bar { max-width: 320px; margin: 0 auto 1.2rem; }
      .quiz-summary .button { display: inline-flex; }
      .quiz-summary .button::after { content: none; }
      .quiz-summary-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.6rem;
      }

      /* --- Stats UI --- */
      .stats-summary {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.6rem;
        margin-bottom: 1.2rem;
      }
      .stat-chip {
        background: var(--c-bg);
        border: 1px solid var(--c-border);
        border-radius: var(--radius-md);
        padding: 0.7rem 0.5rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .stat-num {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--c-primary);
        line-height: 1.1;
      }
      .stat-num small {
        font-size: 0.8rem;
        font-weight: 600;
        margin-left: 0.1rem;
      }
      .stat-label {
        font-size: 0.72rem;
        color: var(--c-muted);
      }
      .stats-heading {
        font-size: 1.05rem;
        margin: 0 0 0.7rem;
      }
      .stats-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.7rem;
      }
      .stat-row {
        background: var(--c-bg);
        border: 1px solid var(--c-border);
        border-radius: var(--radius-md);
        padding: 0.7rem 0.85rem;
      }
      .stat-row-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
        margin-bottom: 0.4rem;
      }
      .stat-row-name { font-weight: 600; font-size: 0.95rem; }
      .stat-row-val { font-weight: 700; color: var(--c-primary); font-size: 0.95rem; }
      .stat-row-sub {
        font-size: 0.78rem;
        color: var(--c-muted);
        margin-top: 0.35rem;
      }
      .note {
        font-size: 0.82rem;
        color: var(--c-muted);
        line-height: 1.7;
        background: var(--c-bg);
        border-radius: var(--radius-md);
        padding: 0.7rem 0.9rem;
        margin-top: 1rem;
      }

      .share-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
        margin-top: 0.6rem;
      }
      .share-row-label {
        font-size: 0.85rem;
        color: var(--c-muted);
      }
      .share-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: #000;
        color: #fff;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 600;
        padding: 0.45rem 0.85rem;
        border-radius: 999px;
        line-height: 1;
        min-height: 36px;
        border: 1px solid #000;
        transition: background-color 0.15s, color 0.15s;
      }
      .share-btn:hover,
      .share-btn:focus-visible {
        background: #fff;
        color: #000;
      }
      .share-btn svg {
        width: 14px;
        height: 14px;
        fill: currentColor;
      }

      .breadcrumbs {
        font-size: 0.85rem;
        color: var(--c-muted);
        margin-bottom: 0.6rem;
      }
      .breadcrumbs a {
        color: var(--c-muted);
        text-decoration: none;
      }
      .breadcrumbs a:hover { text-decoration: underline; }
      .site-footer {
        flex-shrink: 0;
        background: #1a1f36;
        color: #c6d3ec;
        padding: 1.5rem 1rem 2rem;
        margin-top: 2rem;
      }
      .footer-inner {
        max-width: var(--container);
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        font-size: 0.88rem;
      }
      .footer-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.2rem;
      }
      .footer-nav a {
        color: #c6d3ec;
        text-decoration: none;
      }
      .footer-nav a:hover {
        color: #fff;
        text-decoration: underline;
      }
      .footer-copy {
        color: #8ba0c7;
        font-size: 0.8rem;
      }
      @media (min-width: 720px) {
        body { font-size: 17px; }
        .container { padding: 0 1.5rem 2.5rem; }
        .site-header {
          padding: 1.2rem 1.5rem 1.4rem;
          border-radius: 0 0 22px 22px;
        }
        .brand { font-size: 1.25rem; }
        h1 { font-size: 1.75rem; }
        h2 { font-size: 1.35rem; }
        h3 { font-size: 1.12rem; }
        .card { padding: 1.4rem 1.6rem 1.5rem; }
        .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .grid.single { grid-template-columns: 1fr; }
        .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      }
      @media (min-width: 1024px) {
        :root { --container: 1100px; }
      }
      @media (prefers-color-scheme: dark) {
        :root {
          color-scheme: dark;
          --c-bg: #0f1422;
          --c-surface: #1a2238;
          --c-text: #e6ecf8;
          --c-muted: #9aa8c7;
          --c-primary: #6aa3ff;
          --c-primary-strong: #b8d2ff;
          --c-border: #2c3a5c;
          --c-correct: #7fd99a;
          --c-correct-bg: #14331c;
          --c-incorrect: #ff8888;
          --c-incorrect-bg: #3a1414;
        }
        .button {
          background: #1a2238;
          color: var(--c-primary-strong);
        }
        .button.primary {
          background: var(--c-primary);
          color: #0f1422;
          border-color: var(--c-primary);
        }
        button, .choice-btn {
          background: #1a2238;
          color: var(--c-text);
        }
        .ad-slot {
          background: #16203a;
          border-color: #36476f;
          color: var(--c-muted);
        }
        .site-footer { background: #060912; }
      }
      @media (prefers-reduced-motion: reduce) {
        * { transition: none !important; }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main">本文へスキップ</a>
    <header class="site-header" role="banner">
      <div class="site-header-inner">
        <a class="brand" href={base} aria-label={`${siteName} トップへ`}>
          <span class="brand-mark">CAD 2D 2級</span>
          <span>過去問道場</span>
        </a>
        <nav class="site-nav" aria-label="サイトナビゲーション">
          {navItems.map((item) => {
            const normalized = item.href.replace(/\/$/, '');
            const isCurrent = item.exact
              ? normalized === currentPath
              : currentPath.startsWith(item.match);
            return (
              <a href={item.href} aria-current={isCurrent ? 'page' : undefined}>{item.label}</a>
            );
          })}
        </nav>
      </div>
    </header>
    <div class="container">
      <AdSlot position="top" />
      <main id="main">
        <slot />
      </main>
      <AdSlot position="bottom" />
    </div>
    <footer class="site-footer">
      <div class="footer-inner">
        <nav class="footer-nav" aria-label="フッターナビゲーション">
          <a href={base}>トップ</a>
          <a href={`${base}quiz/cad-system/`}>分野別演習</a>
          <a href={`${base}review/`}>復習モード</a>
          <a href={`${base}stats/`}>学習状況</a>
          <a href={`${base}disclaimer/`}>免責事項・お問い合わせ</a>
        </nav>
        <div class="share-row">
          <span class="share-row-label">このサイトをシェア：</span>
          <a class="share-btn" href={shareUrl} target="_blank" rel="noopener noreferrer" aria-label="X (旧Twitter) でシェア">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Xでシェア
          </a>
        </div>
        <p class="footer-copy">© CAD Pages / 無料・登録不要のCAD試験 演習サイト</p>
      </div>
    </footer>
  </body>
</html>
