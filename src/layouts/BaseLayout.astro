---
import AdSlot from '../components/AdSlot.astro';

const { title, description = 'CAD利用技術者試験 2次元2級向けの無料演習サイト' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: light;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        line-height: 1.5;
      }
      body {
        margin: 0;
        background: #f5f7fb;
        color: #1a1f36;
      }
      .container {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 1rem 2rem;
      }
      header {
        background: #1b4d91;
        color: #fff;
        padding: 1rem;
        border-radius: 0 0 14px 14px;
      }
      header h1 {
        margin: 0;
        font-size: 1.1rem;
      }
      nav {
        margin-top: 0.75rem;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      nav a {
        color: #fff;
        text-decoration: none;
        background: rgba(255, 255, 255, 0.15);
        padding: 0.4rem 0.7rem;
        border-radius: 999px;
        font-size: 0.88rem;
      }
      main {
        margin-top: 1rem;
      }
      .card {
        background: #fff;
        border-radius: 12px;
        padding: 1rem;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
      }
      .ad-slot {
        background: #eef2f9;
        border: 1px dashed #8ba0c7;
        border-radius: 10px;
        min-height: 88px;
        display: grid;
        place-items: center;
        color: #5c6b8a;
        margin: 1rem 0;
      }
      .ad-slot::before {
        content: 'AdSense Placeholder';
        font-size: 0.85rem;
      }
      .button,
      button,
      .choice-btn {
        min-height: 48px;
        border-radius: 10px;
        border: 1px solid #c6d3ec;
        background: #fff;
        padding: 0.7rem 0.9rem;
        font-size: 1rem;
      }
      .button {
        display: inline-block;
        text-decoration: none;
        color: #17386b;
        font-weight: 600;
      }
      .choice-btn.correct {
        border-color: #2e7d32;
        background: #e7f5e8;
        color: #1b5e20;
        font-weight: 600;
      }
      .choice-btn.incorrect {
        border-color: #c62828;
        background: #fdecea;
        color: #b71c1c;
        font-weight: 600;
      }
      .grid {
        display: grid;
        gap: 0.7rem;
      }
      footer {
        margin-top: 1.5rem;
        color: #5c6b8a;
        font-size: 0.85rem;
      }
      @media (min-width: 768px) {
        header h1 {
          font-size: 1.25rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>CAD利用技術者試験 2次元2級 道場</h1>
        <nav>
          <a href={base}>トップ</a>
          <a href={`${base}review/`}>復習</a>
          <a href={`${base}stats/`}>学習状況</a>
          <a href={`${base}guide/`}>試験ガイド</a>
        </nav>
      </header>
      <AdSlot position="top" />
      <main>
        <slot />
      </main>
      <AdSlot position="bottom" />
      <footer>© CAD Pages</footer>
    </div>
  </body>
</html>
